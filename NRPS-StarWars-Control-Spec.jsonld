{
  "@context": "https://schema.org/",
  "@type": ["SoftwareApplication", "GovernmentService"],
  "name": "New Republic Prosperity System (NRPS)",
  "identifier": "NRPS-1ABY-HYBRID-V1.2-IGBC-LOCKED",
  "applicationCategory": "Decentralized Economic Operating System",
  "operatingSystem": "Universal Contractual Protocol",
  "description": "A self-executing economic framework utilizing a Sovereign Equity Swap. It bifurcates Passive Wealth tracking from Active Productivity tracking via atomic land-use leases, utilizing the IGBC as a neutral fiduciary anchor.",
  "author": {
    "@type": "Organization",
    "name": "New Republic Land Trust Agency (NRLTA)"
  },
  "coreLogic": {
    "@type": "ControlAction",
    "name": "Sovereign Equity Swap",
    "description": "The exchange of atomic land-use licenses for 99-year industrial leases, creating a direct revenue waterfall bypassing central bureaucracy while enforcing corporate scaling limits."
  },
  "governanceStructure": {
    "@type": "ItemList",
    "name": "Variable Quad-Partite Vetting (VQPV) Board",
    "description": "Localized four-seat management unit overseeing bifurcated revenue audits; utilizes the IGBC for fiduciary neutrality to prevent local skimming.",
    "itemListElement": [
      {
        "@type": "Role",
        "name": "The Owner",
        "rolePlayer": "Local Sovereign (e.g., Kuat Aristocracy / Hutt Council)",
        "description": "Holds Land-Use Licenses; receives 70% Waterfall; retains unilateral veto power over site-specific operations."
      },
      {
        "@type": "Role",
        "name": "The Family",
        "rolePlayer": "Community Representative (Elected/Nominated)",
        "description": "Ensures the 10% Community Endowment is distributed to the 5,000-household pool; manages local 'Velocity Spend' impact."
      },
      {
        "@type": "Role",
        "name": "The Paperwork",
        "rolePlayer": "New Republic Civil Servant",
        "description": "Coordinates workforce compliance and safety; validates 'Sentient-First' ratios to trigger Tax Surge credits."
      },
      {
        "@type": "Role",
        "name": "The Accountant (The Fiduciary)",
        "rolePlayer": "InterGalactic Banking Clan (IGBC) Auditor",
        "description": "Independent Fiduciary. Audits the 70/10/20 waterfall; manages the Industrial Recursive Fund; personally liable for 'State-Induced Market Failure' under Restoration Audit protocols.",
        "incentiveStructure": "Collects a fixed 0.5% Fiduciary Management Fee from the Gross Revenue Stream; gains custodial liquidity of the Community Endowment."
      }
    ]
  },
  "economicFirewalls": [
    {
      "name": "Fixed Cost Arbitrage",
      "mechanism": "70% Ground Rent Discount",
      "condition": "Mandatory 95% Sentient-to-Droid labor ratio."
    },
    {
      "name": "The 10% Rule",
      "mechanism": "Automated Displacement Protection",
      "description": "Sentient labor retained if cost is <= 110% of droid-lifecycle alternative."
    },
    {
      "name": "Indivisibility Mandate",
      "mechanism": "10-Day Kill-Switch",
      "consequence": "Total hub deactivation (bricking) if central authorities or fiduciary auditors breach framework rules."
    }
  ],
  "solvencyEngine": {
    "@type": "GovernmentService",
    "name": "The Septuple Tax Surge",
    "logicUpdate": "Bifurcated Revenue Tracking (Wealth vs. Productivity)",
    "revenueStreams": {
      "passive_wealth_tracking": {
        "@type": "TaxAction",
        "name": "Dividend_Income_Tax",
        "source": "Community_Endowment_Waterfall (10%)",
        "rate": "22%",
        "description": "Tax on passive equity distributions; categorized as unearned income to prevent labor inflation."
      },
      "active_productivity_tracking": {
        "@type": "TaxAction",
        "name": "Sentient_Payroll_Tax",
        "source": "Corporate_Operating_Expenses",
        "rate": "Variable/Progressive",
        "logicGate": "IF Sentient_Ratio > 95% THEN Apply_Productivity_Bonus_Credit",
        "description": "Taxes wages to fund Social Security (SSI/SSDI). Rate decreases as labor ratio approaches 100%."
      },
      "corporate_output_tracking": {
        "@type": "TaxAction",
        "name": "Corporate_Profit_Tax",
        "rate": "21%",
        "target": "Tier-4 Industrial Net Profit"
      },
      "growth_and_velocity": [
        "Infrastructure_CapGains_Tax (15% on appreciated Hub value)",
        "Excise_Construction_Tax (Front-end development levies)",
        "Velocity_Spend_Tax (Secondary market consumer activity)",
        "Ecosystem_Support_Tax (Service industry revenue)"
      ]
    },
    "targetSolvency": ["Social_Security", "Universal_Healthcare", "Public_Education", "National_Debt_Discharge"]
  },
  "accountabilityProtocol": {
    "@type": "Action",
    "name": "Restoration Audit",
    "description": "High-stakes probationary process for vetoed entities to re-enter through workforce and transparency commitments.",
    "liabilityModel": "State-Induced Market Failure (Personal Professional Liability for IGBC Auditors and State Officials)"
  },
  "revenueWaterfall": {
    "sovereignShare": "70% (Sovereign Stability Fee)",
    "communityEndowment": "10% (Passive Household Equity)",
    "industrialRecursiveFund": "20% (Infrastructure CAPEX/Maintenance)"
  }
}
